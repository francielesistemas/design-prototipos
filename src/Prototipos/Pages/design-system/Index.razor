@page "/design-system"
@page "/ds"
@namespace Lar.Prototipos.Pages.DesignSystem

<PageTitle>Design System — Cooperativa Lar</PageTitle>

<div class="ds-layout">

    <aside class="ds-sidebar">
        <div class="ds-sidebar__inner">
            <div class="ds-sidebar__eyebrow rz-text-overline">Navegação</div>
            <nav class="ds-toc">
                <a href="design-system#intro" class="ds-toc__link">Introdução</a>
                <a href="design-system#marca" class="ds-toc__link">Marca e logos</a>
                <a href="design-system#cores-cooperativa" class="ds-toc__link">Cores — Cooperativa</a>
                <a href="design-system#cores-agro" class="ds-toc__link">Cores — Lar Agro</a>
                <a href="design-system#cores-foods" class="ds-toc__link">Cores — Lar Foods</a>
                <a href="design-system#cores-super" class="ds-toc__link">Cores — Lar Supermercados</a>
                <a href="design-system#cores-semanticas" class="ds-toc__link">Cores semânticas</a>
                <a href="design-system#cores-neutras" class="ds-toc__link">Superfícies e neutros</a>
                <a href="design-system#tipografia" class="ds-toc__link">Tipografia</a>
                <a href="design-system#espacamento" class="ds-toc__link">Espaçamento</a>
                <a href="design-system#sombras" class="ds-toc__link">Sombras</a>
                <a href="design-system#componentes" class="ds-toc__link">Componentes</a>
            </nav>
        </div>
    </aside>

    <main class="ds-main">

        <!-- ===== INTRO ===== -->
        <section id="intro" class="ds-section ds-hero">
            <div class="ds-hero__eyebrow rz-text-overline">Design System</div>
            <h1 class="rz-text-h3 ds-hero__title">Cooperativa Lar</h1>
            <p class="rz-text-body1 ds-hero__subtitle">
                Fonte única de verdade pra cores, tipografia, espaçamento e componentes dos protótipos e produtos digitais da Lar.
                Abrange a marca institucional e as três áreas de negócio — Agro, Foods e Supermercados.
            </p>
            <div class="ds-hero__meta">
                <div class="ds-hero__meta-item">
                    <div class="ds-hero__meta-label">Base técnica</div>
                    <div class="ds-hero__meta-value">Radzen Blazor Material</div>
                </div>
                <div class="ds-hero__meta-item">
                    <div class="ds-hero__meta-label">Tipografia</div>
                    <div class="ds-hero__meta-value">CentraleSansRnd / Inter</div>
                </div>
                <div class="ds-hero__meta-item">
                    <div class="ds-hero__meta-label">Radius padrão</div>
                    <div class="ds-hero__meta-value">4px</div>
                </div>
                <div class="ds-hero__meta-item">
                    <div class="ds-hero__meta-label">Grade</div>
                    <div class="ds-hero__meta-value">4px baseline</div>
                </div>
            </div>
        </section>

        <!-- ===== MARCA ===== -->
        <section id="marca" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-primary);">01 · Marca</div>
                <h2 class="rz-text-h4">Logos e símbolo</h2>
                <p class="rz-text-body2 ds-section__desc">
                    A marca Lar tem um coração estilizado como símbolo, apoiado no wordmark "Lar" em peso bold. A versão institucional inclui o descritor "Cooperativa Agroindustrial".
                </p>
                <div class="ds-note">
                    <strong>⚠ Atenção:</strong> os SVGs atuais são aproximações geradas a partir do manual de marca.
                    Substitua pelos SVGs oficiais do marketing dropando os arquivos em <code>wwwroot/assets/logos/</code> com os mesmos nomes — todas as referências continuam funcionando.
                </div>
            </header>

            <div class="ds-logo-grid">
                <div class="ds-logo-card ds-logo-card--light">
                    <div class="ds-logo-card__preview">
                        <img src="assets/logos/lar-symbol-color.svg" alt="Lar símbolo" class="ds-logo-card__img" />
                    </div>
                    <div class="ds-logo-card__info">
                        <div class="rz-text-subtitle2">Símbolo · colorido</div>
                        <div class="rz-text-caption ds-logo-card__path">assets/logos/lar-symbol-color.svg</div>
                        <div class="rz-text-caption ds-logo-card__hint">Uso sobre fundo claro (#FFFFFF ou #FAFAFA)</div>
                    </div>
                </div>

                <div class="ds-logo-card ds-logo-card--dark">
                    <div class="ds-logo-card__preview">
                        <img src="assets/logos/lar-symbol-white.svg" alt="Lar símbolo branco" class="ds-logo-card__img" />
                    </div>
                    <div class="ds-logo-card__info">
                        <div class="rz-text-subtitle2">Símbolo · branco</div>
                        <div class="rz-text-caption ds-logo-card__path">assets/logos/lar-symbol-white.svg</div>
                        <div class="rz-text-caption ds-logo-card__hint">Uso sobre fundo escuro ou colorido</div>
                    </div>
                </div>

                <div class="ds-logo-card ds-logo-card--light ds-logo-card--wide">
                    <div class="ds-logo-card__preview">
                        <img src="assets/logos/lar-institucional-color.svg" alt="Lar Cooperativa Agroindustrial" class="ds-logo-card__img" />
                    </div>
                    <div class="ds-logo-card__info">
                        <div class="rz-text-subtitle2">Institucional · colorido</div>
                        <div class="rz-text-caption ds-logo-card__path">assets/logos/lar-institucional-color.svg</div>
                        <div class="rz-text-caption ds-logo-card__hint">Descritor "Cooperativa Agroindustrial". Materiais institucionais.</div>
                    </div>
                </div>

                <div class="ds-logo-card ds-logo-card--dark ds-logo-card--wide">
                    <div class="ds-logo-card__preview">
                        <img src="assets/logos/lar-institucional-white.svg" alt="Lar Cooperativa Agroindustrial branco" class="ds-logo-card__img" />
                    </div>
                    <div class="ds-logo-card__info">
                        <div class="rz-text-subtitle2">Institucional · branco</div>
                        <div class="rz-text-caption ds-logo-card__path">assets/logos/lar-institucional-white.svg</div>
                        <div class="rz-text-caption ds-logo-card__hint">Descritor sobre fundos escuros.</div>
                    </div>
                </div>
            </div>

            <div class="ds-rules">
                <div class="ds-rules__title rz-text-subtitle1">Regras de uso</div>
                <ul class="ds-rules__list">
                    <li>Respeitar área de proteção mínima ao redor da logo (equivalente à altura do "L").</li>
                    <li>Não distorcer, rotacionar, inclinar ou aplicar efeitos (sombra, gradiente, contorno).</li>
                    <li>Sobre fundo colorido (Agro, Foods, Supermercados), usar a versão branca pra manter contraste.</li>
                    <li>Tamanho mínimo digital: 32px de altura. Tamanho mínimo impresso: 10mm.</li>
                </ul>
            </div>
        </section>

        <!-- ===== CORES COOPERATIVA ===== -->
        <section id="cores-cooperativa" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-primary);">02 · Cores</div>
                <h2 class="rz-text-h4">Cooperativa Lar</h2>
                <p class="rz-text-body2 ds-section__desc">
                    Paleta institucional, usada quando a comunicação representa a Lar como um todo (papelaria, intranet, materiais corporativos).
                    O vermelho do coração é o ponto focal.
                </p>
            </header>

            <div class="ds-palette-group">
                <div class="ds-palette-group__title rz-text-subtitle2">Primárias</div>
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Primary" Hex="#E40046" VarName="--rz-primary" Pantone="710 C" IsDark="true" Note="Vermelho institucional — coração do logo." />
                    <DsColorSwatch Name="Brown institucional" Hex="#3B302D" VarName="--rz-brand-brown" IsDark="true" Note="Marrom escuro do wordmark. Texto forte sobre fundo claro." />
                </div>

                <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Shades do vermelho</div>
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Lighter" Hex="#FF4F7B" VarName="--rz-primary-lighter" Note="Hover suave, tints." />
                    <DsColorSwatch Name="Light" Hex="#EE2F63" VarName="--rz-primary-light" Note="Variação quente do primary." />
                    <DsColorSwatch Name="Default" Hex="#E40046" VarName="--rz-primary" IsDark="true" Note="Cor principal." />
                    <DsColorSwatch Name="Dark" Hex="#B8003A" VarName="--rz-primary-dark" IsDark="true" Note="Hover de botões filled." />
                    <DsColorSwatch Name="Darker" Hex="#8E002D" VarName="--rz-primary-darker" IsDark="true" Note="Active / pressed." />
                </div>
            </div>
        </section>

        <!-- ===== CORES LAR AGRO ===== -->
        <section id="cores-agro" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-agro-primary-dark);">02 · Cores</div>
                <h2 class="rz-text-h4">Lar Agro</h2>
                <p class="rz-text-body2 ds-section__desc">
                    Tabela cromática da Lar Agro faz referência às cores do agronegócio em tons modernos,
                    transmitindo o momento atual e a eficiência da tecnologia.
                </p>
            </header>

            <div class="ds-palette-group">
                <div class="ds-palette-group__title rz-text-subtitle2">Primárias</div>
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Primary dark" Hex="#00594C" VarName="--rz-agro-primary-dark" Pantone="626 C" IsDark="true" Note="Verde escuro principal. Identidade Lar Agro." />
                    <DsColorSwatch Name="Primary light" Hex="#6CC24A" VarName="--rz-agro-primary-light" Pantone="360 C" Note="Verde vibrante, apoio ao primary dark." />
                </div>

                <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Secundárias — apoio em comunicação</div>
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Verde médio" Hex="#3A913F" VarName="--rz-agro-secondary-1" Pantone="7740 C" IsDark="true" />
                    <DsColorSwatch Name="Amarelo limão" Hex="#DBE442" VarName="--rz-agro-secondary-2" Pantone="380 C" />
                    <DsColorSwatch Name="Laranja claro" Hex="#ECA154" VarName="--rz-agro-secondary-3" Pantone="157 C" />
                    <DsColorSwatch Name="Amarelo ouro" Hex="#FFB500" VarName="--rz-agro-secondary-4" Pantone="7549 C" />
                    <DsColorSwatch Name="Amarelo sol" Hex="#F7EA48" VarName="--rz-agro-secondary-5" Pantone="101 C" />
                    <DsColorSwatch Name="Rosa" Hex="#E03E52" VarName="--rz-agro-secondary-6" Pantone="710 C" IsDark="true" />
                </div>
            </div>
        </section>

        <!-- ===== CORES LAR FOODS ===== -->
        <section id="cores-foods" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-foods-primary-2);">02 · Cores</div>
                <h2 class="rz-text-h4">Lar Foods</h2>
                <p class="rz-text-body2 ds-section__desc">
                    Cores quentes pra pertencer à categoria de produtos alimentícios, em tons modernos que transmitem
                    o momento atual e a eficiência da tecnologia.
                </p>
            </header>

            <div class="ds-palette-group">
                <div class="ds-palette-group__title rz-text-subtitle2">Primárias</div>
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Primary 1" Hex="#FFB500" VarName="--rz-foods-primary-1" Pantone="7549 C" Note="Amarelo ouro, referência calorosa." />
                    <DsColorSwatch Name="Primary 2" Hex="#E40046" VarName="--rz-foods-primary-2" Pantone="710 C" IsDark="true" Note="Vermelho — mesmo vermelho institucional." />
                </div>

                <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Secundárias</div>
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Magenta" Hex="#8A1B61" VarName="--rz-foods-secondary-1" Pantone="7649 C" IsDark="true" />
                    <DsColorSwatch Name="Coral" Hex="#FF7F41" VarName="--rz-foods-secondary-2" Pantone="164 C" />
                    <DsColorSwatch Name="Laranja" Hex="#ECA154" VarName="--rz-foods-secondary-3" Pantone="157 C" />
                    <DsColorSwatch Name="Amarelo" Hex="#F7EA48" VarName="--rz-foods-secondary-4" Pantone="101 C" />
                </div>
            </div>
        </section>

        <!-- ===== CORES LAR SUPERMERCADOS ===== -->
        <section id="cores-super" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-super-primary-1);">02 · Cores</div>
                <h2 class="rz-text-h4">Lar Supermercados</h2>
                <p class="rz-text-body2 ds-section__desc">
                    A paleta mais diversa — reflete a variedade de produtos e seções dos supermercados.
                    Auxilia a comunicação e ambientação com muitas opções disponíveis.
                </p>
            </header>

            <div class="ds-palette-group">
                <div class="ds-palette-group__title rz-text-subtitle2">Primárias</div>
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Primary 1" Hex="#470A68" VarName="--rz-super-primary-1" Pantone="2617 C" IsDark="true" Note="Roxo escuro — diferenciador visual." />
                    <DsColorSwatch Name="Primary 2" Hex="#E40046" VarName="--rz-super-primary-2" Pantone="710 C" IsDark="true" Note="Vermelho institucional." />
                </div>

                <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Secundárias</div>
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Magenta" Hex="#8A1B61" VarName="--rz-super-secondary-1" Pantone="7649 C" IsDark="true" />
                    <DsColorSwatch Name="Coral" Hex="#FF7F41" VarName="--rz-super-secondary-2" Pantone="164 C" />
                    <DsColorSwatch Name="Laranja" Hex="#ECA154" VarName="--rz-super-secondary-3" Pantone="157 C" />
                    <DsColorSwatch Name="Amarelo ouro" Hex="#FFB500" VarName="--rz-super-secondary-4" Pantone="7549 C" />
                    <DsColorSwatch Name="Amarelo sol" Hex="#F7EA48" VarName="--rz-super-secondary-5" Pantone="101 C" />
                    <DsColorSwatch Name="Amarelo limão" Hex="#DBE442" VarName="--rz-super-secondary-6" Pantone="380 C" />
                    <DsColorSwatch Name="Verde claro" Hex="#6CC24A" VarName="--rz-super-secondary-7" Pantone="360 C" />
                    <DsColorSwatch Name="Verde médio" Hex="#3A913F" VarName="--rz-super-secondary-8" Pantone="7740 C" IsDark="true" />
                    <DsColorSwatch Name="Verde escuro" Hex="#00594C" VarName="--rz-super-secondary-9" Pantone="626 C" IsDark="true" />
                    <DsColorSwatch Name="Azul marinho" Hex="#003DA5" VarName="--rz-super-secondary-10" Pantone="7692 C" IsDark="true" />
                    <DsColorSwatch Name="Azul" Hex="#0072CE" VarName="--rz-super-secondary-11" Pantone="285 C" IsDark="true" />
                    <DsColorSwatch Name="Azul médio" Hex="#418FDE" VarName="--rz-super-secondary-12" Pantone="279 C" />
                    <DsColorSwatch Name="Azul claro" Hex="#9BCBEB" VarName="--rz-super-secondary-13" Pantone="291 C" />
                </div>
            </div>
        </section>

        <!-- ===== CORES SEMÂNTICAS ===== -->
        <section id="cores-semanticas" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-text-secondary);">02 · Cores</div>
                <h2 class="rz-text-h4">Semânticas (UI)</h2>
                <p class="rz-text-body2 ds-section__desc">
                    Usadas pra estados e feedback na interface. Herdadas do Radzen Material, com nomes
                    <code>Info</code> / <code>Success</code> / <code>Warning</code> / <code>Danger</code>.
                </p>
            </header>

            <div class="ds-palette-group">
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Info" Hex="#003DA5" VarName="--rz-info" IsDark="true" Note="Mensagens informativas." />
                    <DsColorSwatch Name="Success" Hex="#327836" VarName="--rz-success" IsDark="true" Note="Confirmações, aprovações." />
                    <DsColorSwatch Name="Warning" Hex="#ECA154" VarName="--rz-warning" Note="Alertas de atenção (não crítico)." />
                    <DsColorSwatch Name="Danger" Hex="#CC3043" VarName="--rz-danger" IsDark="true" Note="Erros, exclusões, irreversíveis." />
                </div>
            </div>
        </section>

        <!-- ===== CORES NEUTRAS ===== -->
        <section id="cores-neutras" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-text-secondary);">02 · Cores</div>
                <h2 class="rz-text-h4">Superfícies e neutros</h2>
                <p class="rz-text-body2 ds-section__desc">
                    Escala de cinzas pra fundos, divisores, textos e bordas.
                </p>
            </header>

            <div class="ds-palette-group">
                <div class="ds-swatch-grid">
                    <DsColorSwatch Name="Base 0" Hex="#FFFFFF" VarName="--rz-base-0" Note="Superfície principal (card, dialog)." />
                    <DsColorSwatch Name="Base 50" Hex="#FAFAFA" VarName="--rz-base-50" Note="Background geral do app." />
                    <DsColorSwatch Name="Base 100" Hex="#F5F5F5" VarName="--rz-base-100" Note="Superfície alternada." />
                    <DsColorSwatch Name="Base 200" Hex="#EEEEEE" VarName="--rz-base-200" Note="Divisores / hover sutil." />
                    <DsColorSwatch Name="Base 300" Hex="#E0E0E0" VarName="--rz-base-300" Note="Bordas sutis." />
                    <DsColorSwatch Name="Base 400" Hex="#BDBDBD" VarName="--rz-base-400" Note="Placeholders, disabled." />
                    <DsColorSwatch Name="Base 500" Hex="#9E9E9E" VarName="--rz-base-500" Note="Ícones inativos." />
                    <DsColorSwatch Name="Base 600" Hex="#757575" VarName="--rz-base-600" IsDark="true" Note="Texto secundário." />
                    <DsColorSwatch Name="Base 700" Hex="#616161" VarName="--rz-base-700" IsDark="true" Note="Texto secundário enfático." />
                    <DsColorSwatch Name="Base 800" Hex="#424242" VarName="--rz-base-800" IsDark="true" Note="Texto principal (light mode)." />
                    <DsColorSwatch Name="Base 900" Hex="#212121" VarName="--rz-base-900" IsDark="true" Note="Texto máximo contraste." />
                </div>
            </div>
        </section>

        <!-- ===== TIPOGRAFIA ===== -->
        <section id="tipografia" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-primary);">03 · Tipografia</div>
                <h2 class="rz-text-h4">Escala rz/text</h2>
                <p class="rz-text-body2 ds-section__desc">
                    Família primária <code>CentraleSansRnd</code>, com fallback <code>Inter</code>, <code>Roboto</code>, <code>Segoe UI</code>.
                    Pesos disponíveis: Light 300, Book 400, Medium 500, Bold 700.
                </p>
            </header>

            <div class="ds-type-list">
                <DsTypeRow Token="rz-text-h1" Size="96px" Weight="300" LineHeight="112px" Example="Exemplo H1" />
                <DsTypeRow Token="rz-text-h2" Size="60px" Weight="300" LineHeight="72px" Example="Exemplo H2" />
                <DsTypeRow Token="rz-text-h3" Size="48px" Weight="400" LineHeight="56px" Example="Exemplo H3" />
                <DsTypeRow Token="rz-text-h4" Size="34px" Weight="400" LineHeight="36px" Example="Exemplo H4" />
                <DsTypeRow Token="rz-text-h5" Size="24px" Weight="400" LineHeight="auto" Example="Exemplo H5" />
                <DsTypeRow Token="rz-text-h6" Size="20px" Weight="500" LineHeight="24px" Example="Exemplo H6" />
                <DsTypeRow Token="rz-text-subtitle1" Size="16px" Weight="500" LineHeight="24px" Example="Subtitle 1 — usado em título de item de lista" />
                <DsTypeRow Token="rz-text-subtitle2" Size="14px" Weight="500" LineHeight="20px" Example="Subtitle 2 — sub-título compacto" />
                <DsTypeRow Token="rz-text-body1" Size="16px" Weight="400" LineHeight="24px" Example="Body 1 — parágrafo padrão, descrições mais longas e conteúdo principal da interface." />
                <DsTypeRow Token="rz-text-body2" Size="14px" Weight="400" LineHeight="24px" Example="Body 2 — texto secundário, comum em formulários densos e áreas com muito conteúdo." />
                <DsTypeRow Token="rz-text-button" Size="14px" Weight="500" LineHeight="16px" Example="LABEL DE BOTÃO" />
                <DsTypeRow Token="rz-text-caption" Size="12px" Weight="700" LineHeight="16px" Example="Caption — hints, badges" />
                <DsTypeRow Token="rz-text-overline" Size="10px" Weight="400" LineHeight="12px" Example="OVERLINE — EYEBROW, CATEGORIA" />
            </div>
        </section>

        <!-- ===== ESPAÇAMENTO ===== -->
        <section id="espacamento" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-primary);">04 · Espaçamento</div>
                <h2 class="rz-text-h4">Grade de 4px</h2>
                <p class="rz-text-body2 ds-section__desc">
                    Todos os espaçamentos (padding, margin, gap) devem sair desta escala. Evita ajustes arbitrários e mantém ritmo visual.
                </p>
            </header>

            <div class="ds-space-list">
                <DsSpaceRow Token="--rz-space-1" Value="4"  Uses="gap mínimo, padding de badge" />
                <DsSpaceRow Token="--rz-space-2" Value="8"  Uses="padding vertical de botão medium, gap em alert text" />
                <DsSpaceRow Token="--rz-space-3" Value="12" Uses="padding horizontal de botão small" />
                <DsSpaceRow Token="--rz-space-4" Value="16" Uses="padding de card, alert, dialog; gap padrão" />
                <DsSpaceRow Token="--rz-space-5" Value="20" Uses="— (reserva)" />
                <DsSpaceRow Token="--rz-space-6" Value="24" Uses="padding horizontal de botão large, seções" />
                <DsSpaceRow Token="--rz-space-8" Value="32" Uses="seções de conteúdo" />
                <DsSpaceRow Token="--rz-space-10" Value="40" Uses="hero, seções grandes" />
            </div>
        </section>

        <!-- ===== SOMBRAS ===== -->
        <section id="sombras" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-primary);">05 · Elevação</div>
                <h2 class="rz-text-h4">Sombras Material (10 níveis)</h2>
                <p class="rz-text-body2 ds-section__desc">
                    Seguem a escala de elevação do Material Design. Sempre use os tokens — não invente sombras novas.
                </p>
            </header>

            <div class="ds-shadow-grid">
                <DsShadowCard Level="1" Uses="Chip, badge elevado" />
                <DsShadowCard Level="2" Uses="Card, TextBox focado" />
                <DsShadowCard Level="3" Uses="Botão elevado (FAB estático)" />
                <DsShadowCard Level="4" Uses="AppBar, Header" />
                <DsShadowCard Level="5" Uses="Card em hover" />
                <DsShadowCard Level="6" Uses="Menu, Popover" />
                <DsShadowCard Level="7" Uses="FAB em hover" />
                <DsShadowCard Level="8" Uses="Dialog padrão" />
                <DsShadowCard Level="9" Uses="Dialog com ênfase" />
                <DsShadowCard Level="10" Uses="Modal/sheet grande" />
            </div>
        </section>

        <!-- ===== COMPONENTES ===== -->
        <section id="componentes" class="ds-section">
            <header class="ds-section__header">
                <div class="rz-text-overline" style="color: var(--rz-primary);">06 · Componentes</div>
                <h2 class="rz-text-h4">Biblioteca base</h2>
                <p class="rz-text-body2 ds-section__desc">
                    Componentes Radzen com os tokens Lar aplicados. Cada demo abaixo mostra o componente
                    ao vivo e o código Razor pra copiar. Prefira estes aos equivalentes HTML nativos —
                    já cobrem estados, acessibilidade, dark mode e responsividade.
                </p>
            </header>

            <!-- ========== AÇÃO ========== -->
            <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Ação</div>

            <DsComponentDemo Title="Botões — RadzenButton"
                             Description="Variantes visuais (Filled/Outlined/Text/Flat), estilos semânticos, com ou sem ícone, 4 tamanhos."
                             Code="@CodeButton">
                <Preview>
                    <div class="ds-btn-row">
                        <RadzenButton Text="Primary" ButtonStyle="ButtonStyle.Primary" />
                        <RadzenButton Text="Secondary" ButtonStyle="ButtonStyle.Secondary" />
                        <RadzenButton Text="Info" ButtonStyle="ButtonStyle.Info" />
                        <RadzenButton Text="Success" ButtonStyle="ButtonStyle.Success" />
                        <RadzenButton Text="Warning" ButtonStyle="ButtonStyle.Warning" />
                        <RadzenButton Text="Danger" ButtonStyle="ButtonStyle.Danger" />
                    </div>
                    <div class="ds-btn-row">
                        <RadzenButton Text="Filled" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Filled" />
                        <RadzenButton Text="Outlined" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Outlined" />
                        <RadzenButton Text="Text" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Text" />
                        <RadzenButton Text="Flat" ButtonStyle="ButtonStyle.Primary" Variant="Variant.Flat" />
                        <RadzenButton Icon="download" Text="Com ícone" ButtonStyle="ButtonStyle.Primary" />
                        <RadzenButton Text="Disabled" Disabled="true" />
                    </div>
                    <div class="ds-btn-row">
                        <RadzenButton Text="Extra Small" Size="ButtonSize.ExtraSmall" ButtonStyle="ButtonStyle.Primary" />
                        <RadzenButton Text="Small" Size="ButtonSize.Small" ButtonStyle="ButtonStyle.Primary" />
                        <RadzenButton Text="Medium" Size="ButtonSize.Medium" ButtonStyle="ButtonStyle.Primary" />
                        <RadzenButton Text="Large" Size="ButtonSize.Large" ButtonStyle="ButtonStyle.Primary" />
                    </div>
                </Preview>
            </DsComponentDemo>

            <!-- ========== LAYOUT ========== -->
            <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Layout e superfícies</div>

            <DsComponentDemo Title="Cards — RadzenCard"
                             Description="Superfície padrão de conteúdo. Variant Filled (com sombra) ou Outlined (só borda)."
                             Code="@CodeCard">
                <Preview>
                    <div class="ds-card-row">
                        <RadzenCard Style="width: 280px">
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin-bottom: 8px; display: block;">Título do card</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary)">
                                Conteúdo com descrição. Sombra nível 2 por padrão.
                            </RadzenText>
                        </RadzenCard>
                        <RadzenCard Variant="Variant.Outlined" Style="width: 280px">
                            <RadzenText TextStyle="TextStyle.Subtitle1" Style="margin-bottom: 8px; display: block;">Card outlined</RadzenText>
                            <RadzenText TextStyle="TextStyle.Body2" Style="color: var(--rz-text-secondary)">
                                Sem sombra, borda 1px. Ideal pra listas densas.
                            </RadzenText>
                        </RadzenCard>
                    </div>
                </Preview>
            </DsComponentDemo>

            <DsComponentDemo Title="Stat cards (composição)"
                             Description="Composição de card + ícone colorido + label + valor — padrão de dashboard das mockups da Lar. Usa classes utilitárias em ds-tokens.css."
                             Code="@CodeStatCard">
                <Preview>
                    <div class="ds-stat-grid">
                        <div class="ds-stat-card">
                            <div class="ds-stat-card__icon ds-stat-card__icon--info">
                                <span class="material-icons">computer</span>
                            </div>
                            <div class="ds-stat-card__meta">
                                <div class="ds-stat-card__label">Computadores</div>
                                <div class="ds-stat-card__value">23.953</div>
                            </div>
                        </div>
                        <div class="ds-stat-card">
                            <div class="ds-stat-card__icon ds-stat-card__icon--success">
                                <span class="material-icons">article</span>
                            </div>
                            <div class="ds-stat-card__meta">
                                <div class="ds-stat-card__label">Acessos hoje</div>
                                <div class="ds-stat-card__value">4.803</div>
                            </div>
                        </div>
                        <div class="ds-stat-card">
                            <div class="ds-stat-card__icon ds-stat-card__icon--warning">
                                <span class="material-icons">feed</span>
                            </div>
                            <div class="ds-stat-card__meta">
                                <div class="ds-stat-card__label">Notícias ativas</div>
                                <div class="ds-stat-card__value">30</div>
                            </div>
                        </div>
                        <div class="ds-stat-card">
                            <div class="ds-stat-card__icon ds-stat-card__icon--primary">
                                <span class="material-icons">call</span>
                            </div>
                            <div class="ds-stat-card__meta">
                                <div class="ds-stat-card__label">Ramais telefone</div>
                                <div class="ds-stat-card__value">2.029</div>
                            </div>
                        </div>
                    </div>
                </Preview>
            </DsComponentDemo>

            <!-- ========== FORMULÁRIOS ========== -->
            <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Formulários</div>

            <DsComponentDemo Title="FormField (floating label) — RadzenFormField"
                             Description="Envelopa inputs com label flutuante Material. Variant Outlined (padrão) ou Filled."
                             Code="@CodeFormField">
                <Preview>
                    <div class="ds-input-grid">
                        <RadzenFormField Text="Nome do colaborador" Style="width: 100%">
                            <RadzenTextBox @bind-Value="_exemploTexto" />
                        </RadzenFormField>
                        <RadzenFormField Text="Área" Variant="Variant.Filled" Style="width: 100%">
                            <RadzenDropDown TValue="string" Data="@_opcoes" Value="@_opcoes[0]" />
                        </RadzenFormField>
                        <RadzenFormField Text="Competência" Style="width: 100%">
                            <RadzenDatePicker TValue="DateTime?" @bind-Value="_exemploData" DateFormat="MM/yyyy" />
                        </RadzenFormField>
                    </div>
                </Preview>
            </DsComponentDemo>

            <DsComponentDemo Title="Inputs standalone (sem FormField)"
                             Description="Quando o label vive fora do campo, use os inputs Radzen direto."
                             Code="@CodeInputs">
                <Preview>
                    <div class="ds-input-grid">
                        <div>
                            <label class="ds-input-label rz-text-caption">Texto</label>
                            <RadzenTextBox Placeholder="Digite aqui" Style="width: 100%" />
                        </div>
                        <div>
                            <label class="ds-input-label rz-text-caption">Numérico</label>
                            <RadzenNumeric TValue="int" @bind-Value="_exemploNumero" Style="width: 100%" />
                        </div>
                        <div>
                            <label class="ds-input-label rz-text-caption">Dropdown</label>
                            <RadzenDropDown TValue="string" Data="@_opcoes" Value="@_opcoes[0]" Style="width: 100%" />
                        </div>
                        <div>
                            <label class="ds-input-label rz-text-caption">Data</label>
                            <RadzenDatePicker TValue="DateTime?" @bind-Value="_exemploData" DateFormat="dd/MM/yyyy" Style="width: 100%" />
                        </div>
                        <div>
                            <label class="ds-input-label rz-text-caption">Switch</label>
                            <RadzenSwitch @bind-Value="_exemploBool" />
                        </div>
                        <div>
                            <label class="ds-input-label rz-text-caption">Checkbox</label>
                            <RadzenCheckBox TValue="bool" @bind-Value="_exemploBool" />
                        </div>
                    </div>
                </Preview>
            </DsComponentDemo>

            <!-- ========== NAVEGAÇÃO ========== -->
            <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Navegação</div>

            <DsComponentDemo Title="Breadcrumb — RadzenBreadCrumb"
                             Description="Usado logo abaixo do header pra mostrar a hierarquia da página atual."
                             Code="@CodeBreadcrumb">
                <Preview>
                    <RadzenBreadCrumb>
                        <RadzenBreadCrumbItem Path="" Text="Início" />
                        <RadzenBreadCrumbItem Path="acompanhamento" Text="Acompanhamento" />
                        <RadzenBreadCrumbItem Text="Instrução Documental" />
                    </RadzenBreadCrumb>
                </Preview>
            </DsComponentDemo>

            <DsComponentDemo Title="Steps (wizard) — RadzenSteps"
                             Description="Indicador de etapas pra fluxos sequenciais (ex: Instrução Documental de exportação)."
                             Code="@CodeSteps">
                <Preview>
                    <RadzenSteps SelectedIndex="1" ShowStepsButtons="false">
                        <Steps>
                            <RadzenStepsItem Text="Proforma Invoice" />
                            <RadzenStepsItem Text="Instrução Documental" />
                            <RadzenStepsItem Text="Carregamento" />
                            <RadzenStepsItem Text="Embarque Navio" />
                        </Steps>
                    </RadzenSteps>
                </Preview>
            </DsComponentDemo>

            <DsComponentDemo Title="PanelMenu (sidebar) — RadzenPanelMenu"
                             Description="Navegação lateral do app. Item ativo destaca com cor primary e barra lateral esquerda. Usa os ícones do Material Icons."
                             Code="@CodePanelMenu">
                <Preview>
                    <div class="ds-panelmenu-preview">
                        <div class="ds-panelmenu-preview__item ds-panelmenu-preview__item--active">
                            <span class="material-icons">home</span> Início
                        </div>
                        <div class="ds-panelmenu-preview__item">
                            <span class="material-icons">handshake</span> Negociações
                        </div>
                        <div class="ds-panelmenu-preview__item">
                            <span class="material-icons">list_alt</span> Acompanhamento
                        </div>
                        <div class="ds-panelmenu-preview__item">
                            <span class="material-icons">paid</span> Financeiro
                        </div>
                        <div class="ds-panelmenu-preview__item">
                            <span class="material-icons">bar_chart</span> Relatórios
                        </div>
                    </div>
                </Preview>
            </DsComponentDemo>

            <!-- ========== FEEDBACK ========== -->
            <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Feedback</div>

            <DsComponentDemo Title="Alerts — RadzenAlert"
                             Description="Mensagens persistentes dentro da página. Estilos Info, Success, Warning e Danger."
                             Code="@CodeAlert">
                <Preview>
                    <RadzenAlert AlertStyle="AlertStyle.Info" Title="Informativo">Texto explicativo do alerta.</RadzenAlert>
                    <RadzenAlert AlertStyle="AlertStyle.Success" Title="Sucesso">Ação concluída com sucesso.</RadzenAlert>
                    <RadzenAlert AlertStyle="AlertStyle.Warning" Title="Atenção">Algo requer sua atenção, mas não é crítico.</RadzenAlert>
                    <RadzenAlert AlertStyle="AlertStyle.Danger" Title="Erro">Algo deu errado — veja detalhes abaixo.</RadzenAlert>
                </Preview>
            </DsComponentDemo>

            <DsComponentDemo Title="Badges — RadzenBadge"
                             Description="Indicadores pequenos. Inclui pills de status customizadas em ds-tokens.css (rascunho / revisão / aprovado) pra fluxos."
                             Code="@CodeBadge">
                <Preview>
                    <div class="ds-btn-row">
                        <RadzenBadge Text="Primary" BadgeStyle="BadgeStyle.Primary" />
                        <RadzenBadge Text="Secondary" BadgeStyle="BadgeStyle.Secondary" />
                        <RadzenBadge Text="Info" BadgeStyle="BadgeStyle.Info" />
                        <RadzenBadge Text="Success" BadgeStyle="BadgeStyle.Success" />
                        <RadzenBadge Text="Warning" BadgeStyle="BadgeStyle.Warning" />
                        <RadzenBadge Text="Danger" BadgeStyle="BadgeStyle.Danger" />
                    </div>
                    <div class="ds-btn-row">
                        <span class="rz-badge--status rz-badge--status-rascunho">Rascunho</span>
                        <span class="rz-badge--status rz-badge--status-revisao">Em revisão</span>
                        <span class="rz-badge--status rz-badge--status-aprovado">Aprovado</span>
                    </div>
                </Preview>
            </DsComponentDemo>

            <DsComponentDemo Title="Appearance toggle — RadzenAppearanceToggle"
                             Description="Botão de alternância light/dark. Encaixa direto no header do app (como nas suas mockups)."
                             Code="@CodeAppearanceToggle">
                <Preview>
                    <div class="ds-btn-row">
                        <RadzenAppearanceToggle />
                        <RadzenText TextStyle="TextStyle.Caption" Style="color: var(--rz-text-secondary)">
                            Clique pra alternar tema. Persiste via localStorage.
                        </RadzenText>
                    </div>
                </Preview>
            </DsComponentDemo>

            <!-- ========== DATA VIZ ========== -->
            <div class="ds-palette-group__title rz-text-subtitle2" style="margin-top: var(--rz-space-6);">Visualização de dados</div>

            <DsComponentDemo Title="Column chart — RadzenChart"
                             Description="Gráfico de colunas. Use Fill/Stroke com tokens Lar pra manter identidade visual."
                             Code="@CodeChart">
                <Preview>
                    <RadzenChart Style="width: 100%; height: 280px; max-width: 720px;">
                        <RadzenColumnSeries Data="@_acessosPorMes"
                                            CategoryProperty="Mes" ValueProperty="Acessos"
                                            Title="Acessos por mês"
                                            Fill="#E40046" Stroke="#E40046" />
                        <RadzenValueAxis FormatString="{0:N0}" />
                        <RadzenCategoryAxis />
                    </RadzenChart>
                </Preview>
            </DsComponentDemo>

            <DsComponentDemo Title="Donut chart — RadzenChart"
                             Description="Distribuição proporcional. Ideal pro 'Top 5' de dashboards."
                             Code="@CodeDonut">
                <Preview>
                    <RadzenChart Style="width: 100%; height: 280px; max-width: 480px;">
                        <RadzenDonutSeries Data="@_topSistemas"
                                           CategoryProperty="Sistema" ValueProperty="Acessos"
                                           Title="Top sistemas" />
                    </RadzenChart>
                </Preview>
            </DsComponentDemo>
        </section>

    </main>
</div>

@code {
    // ---- Dados de exemplo pra inputs ----
    private string[] _opcoes = new[] { "Opção A", "Opção B", "Opção C" };
    private DateTime? _exemploData = DateTime.Today;
    private int _exemploNumero = 42;
    private bool _exemploBool = true;
    private string _exemploTexto = "";

    // ---- Dados de exemplo pra charts ----
    private record AcessoPorMes(string Mes, double Acessos);
